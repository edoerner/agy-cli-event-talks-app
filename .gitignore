# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   local to the developer.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose not to share it, uncomment the following line:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database of dependencies and should be tracked,
#   unless you have a reason not to.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database of dependencies and should be tracked,
#   unless you have a reason not to.
#pdm.lock

